{
  "manifest_version": 3,
  "name": "{{VITE_APP_NAME}}",
  "version": "0.0.67",
  "action": {
    "default_icon": {
      "192": "icons/android-chrome-192x192.png",
      "512": "icons/android-chrome-512x512.png"
    }
  },
  "icons": {
    "192": "icons/android-chrome-192x192.png",
    "512": "icons/android-chrome-512x512.png"
  },
  "side_panel": {
    "default_path": "index.html"
  },
  "permissions": ["sidePanel", "scripting", "tabs", "activeTab", "storage", "webRequest", "identity", "cookies", "downloads", "notifications", "alarms"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "src/background.js"
  }
}